            <column datatype='real' name='[Discount]' role='measure' type='quantitative' />
            <column caption='KPI Profit Avg ' datatype='string' name='[KPI Sales Avg (copy)_1012162768986114]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([C Y Sales (copy)_1907985522249734]) &gt; WINDOW_AVG(SUM([C Y Sales (copy)_1907985522249734]))&#13;&#10;THEN &apos;above&apos;&#13;&#10;ELSE &apos;below&apos;&#13;&#10;END'>
