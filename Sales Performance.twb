          <datasource-dependencies datasource='federated.1cmdqdm0iwq5gf11noz6d0rsstns'>
            <column caption='C Y Profit' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[C Y Sales (copy)_1907985522249734]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit]&#13;&#10;END' />
            </column>
            <column aggregation='Avg' caption='C Y Discount' datatype='real' default-format='p0%' name='[Calculation_1744441594126350]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])= [Parameters].[Parameter 1] THEN [Discount]&#13;&#10;END' />
            </column>
            <column caption='C Y Sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_1907985517735936]' role='measure' type='quantitative'>
