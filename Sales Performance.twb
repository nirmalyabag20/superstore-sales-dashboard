              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='Bottom Rank profit-ratio' datatype='integer' name='[Calculation_0560268514070533]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RANK_DENSE(SUM([C Y Sales (copy)_1907985522249734]) / SUM([Calculation_1907985517735936]), &apos;asc&apos;)'>
