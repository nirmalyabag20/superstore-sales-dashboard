      <aliases enabled='yes' />
      <column caption='% Diff Quantity' datatype='real' default-format='p0.0%' name='[% Diff Sales (copy)_1144927033970695]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([C Y Sales (copy)_1144927033638916])- SUM([P Y Sales  (copy)_1144927033835526]))/SUM([P Y Sales  (copy)_1144927033835526])' />
      </column>
      <column caption='% Diff Profit' datatype='real' default-format='p0.0%' name='[% Diff Sales (copy)_1907985522507784]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([C Y Sales (copy)_1907985522249734])- SUM([P Y Sales  (copy)_1907985522364423]))/SUM([P Y Sales  (copy)_1907985522364423])' />
      </column>
      <column caption='Top Rank profit-ratio' datatype='integer' name='[Bottom Rank profit-ratio (copy)_0560268515246086]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([C Y Sales (copy)_1907985522249734]) / SUM([Calculation_1907985517735936]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='Avg' caption='P Y Discount' datatype='real' name='[C Y Discount (copy)_1744441594507279]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date])= [Parameters].[Parameter 1]-1 THEN [Discount]&#13;&#10;END' />
      </column>
      <column caption='C Y Quantity' datatype='integer' default-format='n0,K;-0,K' name='[C Y Sales (copy)_1144927033638916]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Quantity]&#13;&#10;END' />
      </column>
      <column caption='P Y Sales ' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[C Y Sales (copy)_1907985518264322]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Sales]&#13;&#10;END' />
      </column>
      <column caption='C Y Profit' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[C Y Sales (copy)_1907985522249734]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit]&#13;&#10;END' />
      </column>
      <column caption='Discount Impact Insight' datatype='string' name='[Calculation_0560268502179842]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1744441594126350]) &gt; WINDOW_AVG(AVG([Calculation_1744441594126350])) &#13;&#10;AND SUM([C Y Sales (copy)_1907985522249734]) &lt; 0 THEN &#13;&#10;&quot;Above-average discount is likely driving losses&quot;&#13;&#10;ELSEIF SUM([C Y Sales (copy)_1907985522249734]) &lt; 0 THEN &#13;&#10;&quot;Loss driven by factors beyond discount&quot;&#13;&#10;ELSE &#13;&#10;&quot;Healthy profitability&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Bottom Rank profit-ratio' datatype='integer' name='[Calculation_0560268514070533]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([C Y Sales (copy)_1907985522249734]) / SUM([Calculation_1907985517735936]), &apos;asc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='KPI CY Less PY' datatype='string' name='[Calculation_1012162761084928]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Calculation_1907985517735936]) &lt; SUM([C Y Sales (copy)_1907985518264322]) THEN &apos;⬤&apos;&#13;&#10;ELSE &apos;&apos;&#13;&#10;END' />
      </column>
      <column caption='KPI Sales Avg' datatype='string' name='[Calculation_1012162768142337]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Calculation_1907985517735936]) &gt; WINDOW_AVG(SUM([Calculation_1907985517735936]))&#13;&#10;THEN &apos;above&apos;&#13;&#10;ELSE &apos;below&apos;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='Sum' caption='Current Year' datatype='integer' default-format='n0;-0' name='[Calculation_1144927018037248]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
      </column>
      <column aggregation='Sum' caption='Previous Year' datatype='integer' default-format='n0;-0' name='[Calculation_1144927018147841]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1]-1' />
      </column>
      <column caption='PR - Profit Ratio CY' datatype='real' default-format='p0.0%' name='[Calculation_1744441564655616]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit] END) / SUM(IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Sales] END)' />
      </column>
      <column caption='AOV - Avg Order Value CY' datatype='real' name='[Calculation_1744441564925953]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Order ID])' />
      </column>
      <column caption='PR - Profit Ratio PY' datatype='real' default-format='p0.0%' name='[Calculation_1744441566609410]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Order Date]) = [Parameters].[Parameter 1] - 1 THEN [Profit] END) / SUM(IF YEAR([Order Date]) = [Parameters].[Parameter 1] - 1 THEN [Sales] END)' />
      </column>
      <column caption='PR - % Diff Profit Ratio' datatype='real' default-format='p0%' name='[Calculation_1744441571680262]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1744441564655616] - [Calculation_1744441566609410]) / [Calculation_1744441566609410]' />
